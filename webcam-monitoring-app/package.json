{
  "name": "webcam-monitoring-root",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n \"ai,api,ui\" -c \"magenta,cyan,green\" \"npm run dev:ai\" \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:ai":  "cd ai-service && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:api": "cd backend && npm run dev",
    "dev:ui":  "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
