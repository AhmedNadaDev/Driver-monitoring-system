BACKEND_PORT=4000
MONGO_URI=mongodb://localhost:27017/driver-monitoring

FRONTEND_ORIGIN=http://localhost:5174
AI_SERVICE_URL=http://localhost:8000
AI_HEALTH_PATH=/health
AI_PREDICT_PATH=/predict

EVENT_COOLDOWN_MS=10000
SMOKING_EVENT_MIN_CONF=0.30
DROWSY_EVENT_MIN_CONF=0.35
CELLPHONE_EVENT_MIN_CONF=0.30
BELT_EVENT_MIN_CONF=0.30

MAX_FRAME_BYTES=400000
INFER_RATE_LIMIT_PER_MIN=60
VITE_WEBCAM_BACKEND_URL=http://localhost:4000

# ── Smart Alerts / n8n Integration ──────────────────────────────────────────
# Production URL — يشتغل دايماً بعد Publish في n8n:
# N8N_WEBHOOK_URL=https://ahmednadaahmed.app.n8n.cloud/webhook/driver-violation-alert
# Test URL — للتجربة فقط (يشتغل لما تضغط "Listen for test event" في n8n):
N8N_WEBHOOK_URL=https://ahmednadaahmed.app.n8n.cloud/webhook-test/driver-violation-alert

# Set to false to silence all alert forwarding without code changes.
ALERT_ENABLED=true

# Minimum confidence score [0.0 – 1.0] required before an alert is forwarded.
# 0 = forward every detected violation (useful while testing).
# Recommended for production: 0.5
ALERT_MIN_CONFIDENCE=0
