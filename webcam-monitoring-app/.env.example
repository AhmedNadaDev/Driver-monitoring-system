### Root example env (copy to each service as needed)

# Required by spec
BACKEND_PORT=5000
AI_SERVICE_PORT=8000
FRONTEND_PORT=5173
SMOKING_MODEL_PATH=./models/smoking_model.pt
DROWSINESS_MODEL_PATH=./models/drowsiness_model.pt
INFERENCE_INTERVAL_MS=500
EVENT_COOLDOWN_MS=10000
SNAPSHOT_BASE_DIR=./storage/snapshots
LOGS_BASE_DIR=./storage/logs

### Derived convenience values
FRONTEND_ORIGIN=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000
INFERENCE_INTERVAL_MS_DEFAULT=500

# Minimum confidence required to consider an event (before cooldown)
SMOKING_EVENT_MIN_CONF=0.30
DROWSY_EVENT_MIN_CONF=0.35

# Limits payload size for incoming frames
MAX_FRAME_BYTES=400000

# Python AI service (FastAPI)
AI_SMOKING_MODEL_PATH=./models/smoking_model.pt
AI_DROWSINESS_MODEL_PATH=./models/drowsiness_model.pt
AI_CONF_THRES=0.25
AI_IMAGE_MAX_EDGE=640

### Frontend (Vite)
VITE_BACKEND_URL=http://localhost:5000
VITE_INFERENCE_INTERVAL_MS=500
VITE_CAPTURE_QUALITY=0.75
VITE_CAPTURE_MAX_EDGE=640

