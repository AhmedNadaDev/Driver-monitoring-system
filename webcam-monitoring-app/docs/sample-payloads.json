  "n8nIfConditions": {
    "_description": "Recommended IF conditions for the n8n flow.",
    "alertOnAll": "No additional condition — every violation above ALERT_MIN_CONFIDENCE is forwarded.",
    "alertOnCriticalOrDrowsy": {
      "operator": "OR",
      "conditions": [
        { "field": "body.type",          "operator": "equals",            "value": "drowsy"    },
        { "field": "body.severityLevel", "operator": "equals",            "value": "critical"  },
        { "field": "body.confidence",    "operator": "greaterThan",       "value": 0.8         }
      ]
    },
    "alertOnHighAndAbove": {
      "field": "body.severityLevel",
      "operator": "is in",
      "value": ["high", "critical"]
    }
  },

  "manualTestCurl": {
    "_description": "Use this curl command to manually trigger an alert for testing.",
    "command": "curl -X POST http://localhost:4000/api/alerts/violation -H 'Content-Type: application/json' -d '{\"type\":\"drowsy\",\"confidence\":0.91,\"driverId\":\"<MONGO_DRIVER_ID>\",\"routeId\":\"<MONGO_ROUTE_ID>\",\"busId\":\"<MONGO_BUS_ID>\",\"tripId\":\"<MONGO_TRIP_ID>\"}'"
  }
}
