# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# MongoDB database and collection names
MONGODB_DATABASE=driver-monitoringnew
MONGODB_COLLECTION=trips

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (options: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768)
GROQ_MODEL=llama-3.3-70b-versatile

# Embedding model (sentence-transformers model name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Atlas Vector Search index name (must match the index created in Atlas UI)
VECTOR_INDEX_NAME=trip_vector_index

# Number of top results to retrieve
TOP_K=5

# Conversational memory (session-based)
ENABLE_MEMORY=true
MEMORY_MAX_TURNS=5
